# Analytics e marketing (carregados somente após consentimento de cookies)
# VITE_GA_ID=G-XXXXXXXXXX
# VITE_GTM_ID=GTM-XXXXXXX
# VITE_META_PIXEL_ID=XXXXXXXXXXXXXXX

# Use GTM OU GA — se ambos estiverem definidos, GTM tem prioridade.

# Server-only (Worker): deve ser Secret no Cloudflare, NÃO só na API/VPS.
# Dashboard → Workers → agencia-toro-site → Settings → Variables → Add (Encrypt)
# Nome exato: LEAD_INGEST_SECRET — mesmo valor do deploy/.env da API.
# Ou: npx wrangler secret put LEAD_INGEST_SECRET
# Use 127.0.0.1 (não localhost) — Node no Windows resolve localhost para IPv6 (::1)
API_URL=http://127.0.0.1:3333
LEAD_INGEST_SECRET=change-me-lead-ingest-secret
